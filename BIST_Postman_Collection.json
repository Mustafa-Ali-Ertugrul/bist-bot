{
  "info": {
    "name": "BIST Bot Performance Test",
    "description": "API performans testi için endpoint'ler",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "2. Dashboard",
      "item": [
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/"
          }
        }
      ]
    },
    {
      "name": "3. Scan API",
      "item": [
        {
          "name": "POST /api/scan",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/scan",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        }
      ]
    },
    {
      "name": "4. Analyze Single Stock",
      "item": [
        {
          "name": "GET /api/analyze/THYAO",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/analyze/THYAO",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analyze", "THYAO"]
            }
          }
        },
        {
          "name": "GET /api/analyze/ASELS",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/analyze/ASELS",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analyze", "ASELS"]
            }
          }
        }
      ]
    },
    {
      "name": "5. Signals History",
      "item": [
        {
          "name": "GET /api/signals/history",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/signals/history?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "signals", "history"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "6. Stats",
      "item": [
        {
          "name": "GET /api/stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/stats"
          }
        }
      ]
    }
  ]
}