# ==============================================================================
# BIST BOT - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================

# --- Telegram (Notification)
TELEGRAM_BOT_TOKEN="your_bot_token_here" # Telegram bot token
TELEGRAM_CHAT_ID="your_chat_id_here" # Telegram kanalı veya kullanıcı ID'si
TELEGRAM_MIN_SCORE=48 # Telegram'a gidecek sinyaller için minimum skor (STRONG_BUY_THRESHOLD ile eşleşmeli)
NOTIFICATION_MAX_RETRIES=3 # Telegram gönderim hata deneme sayısı
NOTIFICATION_RETRY_DELAY=5 # Telegram gönderim hata deneme arası bekleme (sn)
SIGNAL_TTL_MINUTES=60 # Sinyal geçerlilik süresi (dakika). Bu süreden eski sinyaller expired olarak işaretlenir.

# --- Database
DATABASE_URL="sqlite:///bist_signals.db" # SQLAlchemy DB bağlantı dizesi
DB_PATH="bist_signals.db" # Veritabanı dosya yolu

# --- Market Hours (Server)
MARKET_OPEN_HOUR=9 # BIST açılış saati
MARKET_CLOSE_HOUR=18 # BIST kapanış saati
MARKET_WARMUP_MINUTES=15 # Açılış sonrası bekleme süresi
MARKET_HALF_DAY_HOUR=13 # Yarım gün (tatil öncesi) kapanış saati
SCAN_INTERVAL_MINUTES=15 # Tarama sıklığı (dakika)

# --- Indicators (Trading)
RSI_PERIOD=14 # RSI periyodu
RSI_OVERSOLD=30 # RSI aşırı satım sınırı
RSI_OVERBOUGHT=70 # RSI aşırı alım sınırı
SMA_FAST=5 # Hızlı SMA (Basit Hareketli Ortalama)
SMA_SLOW=20 # Yavaş SMA
EMA_FAST=12 # Hızlı EMA (Üstel Hareketli Ortalama)
EMA_SLOW=26 # Yavaş EMA
EMA_LONG=200 # Uzun EMA (Trend belirleyici)
MACD_FAST=12 # MACD Hızlı
MACD_SLOW=26 # MACD Yavaş
MACD_SIGNAL=9 # MACD Sinyal periyodu
BOLLINGER_PERIOD=20 # Bollinger bant periyodu
BOLLINGER_STD=2.0 # Bollinger standart sapması
ADX_THRESHOLD=20 # Trend gücü (ADX) için min sınır
VOLUME_CONFIRM_MULTIPLIER=1.5 # Hacim onayı için ortalamanın kaç katı olmalı
VOLUME_SPIKE_MULTIPLIER=1.5 # Hacim patlaması eşiği

# --- Data Provider (Data)
DATA_PROVIDER="yfinance" # Veri sağlayıcı: 'yfinance', 'official', vb.
DATA_PERIOD="3mo" # Çekilecek geçmiş veri süresi
DATA_INTERVAL="1d" # Mum periyodu (örn: 1d, 1h, 15m)
RATE_LIMIT_SECONDS=2.0 # İstekler arası bekleme süresi
ENABLE_REALTIME_SCRAPING=true # BIST canlı fiyatlarını çekmeyi aç/kapat
OFFICIAL_VENDOR="generic" # Resmi sağlayıcı adı (matriks, finnet, vb)
OFFICIAL_API_BASE_URL="" # Resmi API base URL
OFFICIAL_API_KEY="" # Resmi API Key
OFFICIAL_USERNAME="" # Resmi API kullanıcı adı
OFFICIAL_PASSWORD="" # Resmi API şifresi
OFFICIAL_TIMEOUT=30.0 # Resmi API zaman aşımı (saniye)
OFFICIAL_MAX_RETRIES=3 # Resmi API max hata tekrarı
OFFICIAL_RETRY_BACKOFF_SECONDS=1.0 # Resmi API hata bekleme payı
OFFICIAL_AUTH_ENDPOINT="" # Resmi API Auth Endpoint
OFFICIAL_HISTORY_ENDPOINT="" # Resmi API Tarihçe Endpoint
OFFICIAL_BATCH_ENDPOINT="" # Resmi API Çoklu data endpoint
OFFICIAL_QUOTE_ENDPOINT="" # Resmi API Fiyat endpoint
OFFICIAL_UNIVERSE_ENDPOINT="" # Resmi API Sembol listesi endpoint

# --- MTF (Multi-Timeframe)
MTF_ENABLED=true # Çoklu zaman dilimi onayı aktif/pasif
MTF_TREND_PERIOD="6mo" # Ana trend kontrolü için geçmiş veri
MTF_TREND_INTERVAL="1d" # Ana trend mum periyodu
MTF_TRIGGER_PERIOD="1mo" # İşlem tetikleyici veri süresi
MTF_TRIGGER_INTERVAL="15m" # Sinyal tetikleyici mum periyodu

# --- Risk
CORRELATION_THRESHOLD=0.70 # Sepetteki hisseler arası max korelasyon
CORRELATION_RISK_STEP=0.35 # Korele hisse gelirse risk düşürme katsayısı
CORRELATION_MIN_SCALE=0.25 # Korelasyondan dolayı düşülecek min risk sırı
CORRELATION_MAX_CLUSTER=2 # Aynı anda tutulabilecek max korele hisse
ATR_BASELINE_PCT=0.025 # ATR stop referans yüzdesi
ATR_MIN_RISK_SCALE=0.35 # ATR yüksekse riski düşürme katsayısı
MAX_POSITION_CAP_PCT=5.0 # Tek hisseye girilecek max bakiye %
MAX_SECTOR_CAP_PCT=20.0 # Aynı sektöre girilecek max bakiye %
MAX_TOTAL_RISK_PCT=2.0 # Tek işlemde riske edilen max ana para %
KELLY_FRACTION_SCALE=0.25 # Kelly kriteri uygulama oranı
MIN_SIGNAL_PROBABILITY=0.50 # İşleme girmek için min. olasılık
MIN_LIQUIDITY_VALUE_TL=0.0 # Hacim/Likidite filtresi (TL)
DAILY_LOSS_CAP_PCT=3.0 # Günlük max kayıp limiti (%)

# --- Cache
FETCH_CACHE_TTL_SECONDS=900.0 # Standart veri önbellek ömrü
INTRADAY_FETCH_CACHE_TTL_SECONDS=120.0 # Gün içi veri önbellek ömrü
ANALYSIS_CACHE_TTL_SECONDS=180.0 # Analiz sonuçları önbellek ömrü
REALTIME_QUOTE_CACHE_TTL_SECONDS=30.0 # Canlı fiyat önbellek ömrü

# --- Flask/JWT (Server & Auth)
PORT=5000 # veya FLASK_PORT
FLASK_DEBUG=false # Debug modu
LOG_FORMAT="console" # Log formatı (console veya json)
LOG_LEVEL="INFO" # Log seviyesi (DEBUG, INFO, WARNING, ERROR)
API_BASE_URL="http://localhost:5000" # Dışarıdan erişim URL'i
RATE_LIMIT_STORAGE_URI="memory://" # Flask-Limiter veritabanı url (redis vb)
SENTRY_DSN="" # Hata izleme (Sentry) URL
ENVIRONMENT="production" # Ortam (development, staging, production)
STREAMLIT_SCAN_COOLDOWN_SECONDS=8.0 # Web UI tarama butonu bekleme süresi
STREAMLIT_ANALYZE_COOLDOWN_SECONDS=4.0 # Web UI analiz bekleme süresi
ALLOW_PUBLIC_REGISTRATION=false # Herkese açık üyelik
CORS_ORIGINS="*" # İzin verilen CORS adresleri virgülle ayırarak
# Generate a long random secret and provide it via environment variables or a secret manager in production.
JWT_SECRET_KEY=

# --- Auth Bootstrap
ADMIN_BOOTSTRAP_EMAIL="admin@bistbot.com" # Boot sırasında yaratılacak admin emaili
# IMPORTANT: This must be a bcrypt hash, NOT a plain-text password.
# Generate with: python -c "from bcrypt import hashpw, gensalt; print(hashpw(b'your_password', gensalt()).decode())"
# Never ship a default plain-text password in production.
ADMIN_BOOTSTRAP_PASSWORD_HASH="replace_with_bcrypt_hash" # Admin bcrypt hash

# --- Capital & Broker (Trading & Broker)
INITIAL_CAPITAL=100000.0 # Analiz başlangıç bakiyesi
BROKER_PROVIDER="paper" # Broker entegrasyonu ('paper', 'algolab' vb)
ALGOLAB_API_KEY="" # Algolab API key
ALGOLAB_USERNAME="" # Algolab Kullanıcı adı
ALGOLAB_PASSWORD="" # Algolab Şifre
ALGOLAB_OTP_CODE="" # Algolab kalıcı OTP (varsa)
ALGOLAB_DRY_RUN=true # Dry run (emirler borsaya gitmez)
AUTO_EXECUTE=false # Sinyalleri otomatik işle (algolab)
CONFIRM_LIVE_TRADING=false # Canlı işlemi onaylıyorum flag'i
AUTO_EXECUTE_WARN_MAX_QUANTITY=100000 # Çok yüksek lot gelirse uyar

# --- ML (Machine Learning)
ML_SEQUENCE_LENGTH=60 # LSTM gibi modeller için sıra boyu (mum)
ML_EPOCHS=50 # Eğitim devir sayısı
ML_BATCH_SIZE=32 # Eğitim batch boyutu
ML_MODEL_PATH="models" # Model kayıt dizini

# --- Benchmark (Data)
BENCHMARK_TICKER="^XU100" # Kıyaslama endeksi
BENCHMARK_TICKER_ALT="XRXIST.IS" # Alternatif endeks ticker

# --- Transaction Costs & Slippage (Trading)
COMMISSION_BUY=0.0002 # Alım komisyonu (binde 2 = 0.0002)
COMMISSION_SELL=0.0002 # Satım komisyonu
BSMV=0.0005 # BSMV (binde 5 v.s.)
SLIPPAGE=0.001 # Fiyat kayması miktarı default
SLIPPAGE_PCT=0.001 # Fiyat kayması %
SLIPPAGE_PENALTY_RATIO=0.15 # Backtest kayma cezası katsayısı
SLIPPAGE_MAX_CAP=0.02 # Fiyat kayması için maksimum tavan %

# --- Score Thresholds (Trading)
STRONG_BUY_THRESHOLD=48 # Güçlü Al için min skor
BUY_THRESHOLD=20 # Al için min skor
WEAK_BUY_THRESHOLD=8 # Zayıf Al min skor
WEAK_SELL_THRESHOLD=-8 # Zayıf sat eşiği
SELL_THRESHOLD=-20 # Sat eşiği
STRONG_SELL_THRESHOLD=-48 # Güçlü Sat eşiği
SIDEWAYS_EXTRA_THRESHOLD=5.0 # Yatay piyasada marj payı
MOMENTUM_CONFIRMATION_THRESHOLD=4.0 # Momentum sinyali kırılımı onayı

# --- Walkforward (Trading)
WALKFORWARD_TRAIN_DAYS=180 # Walkforward analiz eğitim boyutu (gün)
WALKFORWARD_TEST_DAYS=30 # Walkforward analiz test boyutu (gün)

# --- Sector (Trading)
SECTOR_LIMIT=2 # Aynı anda portföye girebilecek aynı sektör hissesi

# --- Paper (Trading)
PAPER_MODE=false # Sanal portföyü etkinleştir/devre dışı bırak
PAPER_TRADES_TABLE="paper_trades" # Sanal işlem DB tablosu

# --- Backtest Costs (Backtest)
BACKTEST_COMMISSION_PCT=0.001 # Backtest standart komisyon
BACKTEST_COMMISSION_BUY_PCT=0.001 # Backtest alım komisyonu
BACKTEST_COMMISSION_SELL_PCT=0.001 # Backtest satım komisyonu
BACKTEST_SLIPPAGE_PCT=0.0005 # Backtest slippage
