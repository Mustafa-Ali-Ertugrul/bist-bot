# Telegram Bot Ayarlari
# Bot token almak icin: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=buraya_bot_token_yaz
TELEGRAM_BOT_TOKEN_FILE=

# Chat ID almak icin: https://t.me/userinfobot
TELEGRAM_CHAT_ID=buraya_chat_id_yaz

# Opsiyonel uygulama ayarlari
FLASK_DEBUG=0
FLASK_PORT=5000
API_BASE_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:8501
RATE_LIMIT_STORAGE_URI=memory://
JWT_SECRET_KEY=change_me_random_32_chars
JWT_SECRET_KEY_FILE=
DATABASE_URL=
DB_PATH=data/bist_signals.db
ADMIN_BOOTSTRAP_EMAIL=admin@bistbot.local
ADMIN_BOOTSTRAP_PASSWORD_HASH=<scrypt_hash>
ALLOW_PUBLIC_REGISTRATION=false
INITIAL_CAPITAL=100000
TELEGRAM_MIN_SCORE=48
PAPER_MODE=false
MARKET_WARMUP_MINUTES=15
MARKET_HALF_DAY_HOUR=13
MTF_ENABLED=true
CORRELATION_THRESHOLD=0.70
CORRELATION_RISK_STEP=0.35
CORRELATION_MIN_SCALE=0.25
CORRELATION_MAX_CLUSTER=2
ATR_BASELINE_PCT=0.025
ATR_MIN_RISK_SCALE=0.35
KELLY_FRACTION_SCALE=0.25
MIN_SIGNAL_PROBABILITY=0.50
MIN_LIQUIDITY_VALUE_TL=0
DAILY_LOSS_CAP_PCT=0
ALGOLAB_API_KEY=
ALGOLAB_USERNAME=
ALGOLAB_PASSWORD=
ALGOLAB_PASSWORD_FILE=
ALGOLAB_DRY_RUN=true
BROKER_PROVIDER=paper
AUTO_EXECUTE=false
CONFIRM_LIVE_TRADING=false

# Official Data Provider (Matriks / Foreks / Finnet vb.)
# DATA_PROVIDER=official
# OFFICIAL_API_BASE_URL=https://api.example.com
# OFFICIAL_API_KEY=your_api_key
# OFFICIAL_USERNAME=your_username
# OFFICIAL_PASSWORD=your_password
# OFFICIAL_PASSWORD_FILE=/run/secrets/official_password
# OFFICIAL_TIMEOUT=30
# OFFICIAL_MAX_RETRIES=3
